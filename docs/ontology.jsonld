}, {
  "@id" : "https://paitools.github.io/HPCCOntology/HPCC.owl",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-02-09"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@id" : "_:genid1"
  }, {
    "@id" : "_:genid2"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "HPCC – HPC Cooling Ontology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The HPCC Ontology provides a semantic model for representing HPC thermal management telemetry. It extends the W3C SSN/SOSA standard to capture HPC cooling concepts, including heat pumps, heat exchangers, pumps, coolers, and re-coolers. Designed for the datacenter thermal management domain, the ontology supports anomaly detection, real-time condition monitoring, and advanced system analytics."
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://qudt.org/3.0.0/schema/qudt"
  }, {
    "@id" : "http://www.w3.org/ns/sosa/"
  }, {
    "@id" : "http://www.w3.org/ns/ssn/"
  } ],
  "http://xmlns.com/foaf/0.1/fundedBy" : [ {
    "@id" : "http://example.org/individuals#DTEC"
  } ]
} ]