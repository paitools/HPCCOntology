<?xml version="1.0"?>
<rdf:RDF xmlns="https://paitools.github.io/HPCCOntology/HPCC.owl#"
     xml:base="https://paitools.github.io/HPCCOntology/HPCC.owl"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ex="http://example.org/individuals#"
     xmlns:dct="http://purl.org/dc/terms/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:ssn="http://www.w3.org/ns/ssn/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:bibo="http://purl.org/ontology/bibo/"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:hpcc="http://example.org/hpcc#"
     xmlns:qudt="http://qudt.org/schema/qudt/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:sosa="http://www.w3.org/ns/sosa/"
     xmlns:unit="http://qudt.org/vocab/unit/"
     xmlns:vaem="http://www.linkedmodel.org/schema/vaem#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:dtype="http://www.linkedmodel.org/schema/dtype#"
     xmlns:schema="http://schema.org/">
    <owl:Ontology rdf:about="https://paitools.github.io/HPCCOntology/HPCC.owl">
        <owl:imports rdf:resource="http://qudt.org/3.0.0/schema/qudt"/>
        <owl:imports rdf:resource="http://www.w3.org/ns/sosa/"/>
        <owl:imports rdf:resource="http://www.w3.org/ns/ssn/"/>
        <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-09</dct:created>
        <dct:creator>
            <rdf:Description>
                <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
                <foaf:homepage rdf:resource="https://orcid.org/0000-0001-7757-094X"/>
                <foaf:mbox rdf:resource="mailto:ivanovip@hsu-hh.de"/>
                <foaf:name>Pavle Ivanovic</foaf:name>
            </rdf:Description>
        </dct:creator>
        <dct:creator>
            <rdf:Description>
                <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
                <foaf:mbox rdf:resource="mailto:wanniars@hsu-hh.de"/>
                <foaf:name>Shashini Wanniarachchi</foaf:name>
            </rdf:Description>
        </dct:creator>
        <dct:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dct:title>HPCC – HPC Cooling Ontology</dct:title>
        <rdfs:comment xml:lang="en">The HPCC Ontology provides a semantic model for representing HPC thermal management telemetry. It extends the W3C SSN/SOSA standard to capture HPC cooling concepts, including heat pumps, heat exchangers, pumps, coolers, and re-coolers. Designed for the datacenter thermal management domain, the ontology supports anomaly detection, real-time condition monitoring, and advanced system analytics.</rdfs:comment>
        <foaf:fundedBy rdf:resource="http://example.org/individuals#DTEC"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://xmlns.com/foaf/0.1/fundedBy -->

    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/fundedBy"/>
    


    <!-- http://xmlns.com/foaf/0.1/homepage -->

    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/homepage"/>
    


    <!-- http://xmlns.com/foaf/0.1/mbox -->

    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/mbox"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/hpcc#hasTargetValue -->

    <owl:ObjectProperty rdf:about="http://example.org/hpcc#hasTargetValue">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:range rdf:resource="http://example.org/hpcc#TargetValue"/>
        <rdfs:comment>Links a sensor to its corresponding target value or target tolerance, where the distinction is inferred from the associated measurement unit.</rdfs:comment>
        <rdfs:label>has target value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/hpcc#setForSensor -->

    <owl:ObjectProperty rdf:about="http://example.org/hpcc#setForSensor">
        <rdfs:domain rdf:resource="http://example.org/hpcc#TargetValue"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment>Inverse of hpcc:hasTargetValue, linking a target value or target tolerance to the corresponding sensor.</rdfs:comment>
        <rdfs:label>set for sensor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://qudt.org/schema/qudt/hasUnit -->

    <owl:ObjectProperty rdf:about="http://qudt.org/schema/qudt/hasUnit">
        <rdfs:range rdf:resource="http://qudt.org/schema/qudt/Unit"/>
        <rdfs:label>has unit</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/hasFeatureOfInterest -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/hasFeatureOfInterest">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:label>has feature of interest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/hosts -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/hosts">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:label>hosts</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/isFeatureOfInterestOf -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/isFeatureOfInterestOf">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>is feature of interest of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/isHostedBy -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/isHostedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
        <rdfs:label>is hosted by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/isObservedBy -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/isObservedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:label>is observed by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/madeBySensor -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/madeBySensor">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:label>made by sensor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/madeObservation -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/madeObservation">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>made observation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/observedProperty -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/observedProperty">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:label>observed property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/observes -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/observes">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:label>observes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/ssn/detects -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/ssn/detects">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Stimulus"/>
        <rdfs:label>detects</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/ssn/hasSubSystem -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/ssn/hasSubSystem">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/ssn/System"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/ssn/System"/>
        <rdfs:label>has subsystem</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/ssn/isProxyFor -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/ssn/isProxyFor">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Stimulus"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:label>is proxy for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://qudt.org/schema/qudt/numericValue -->

    <owl:DatatypeProperty rdf:about="http://qudt.org/schema/qudt/numericValue">
        <rdfs:label>numeric value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/sosa/hasSimpleResult -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/sosa/hasSimpleResult">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:label>has simple result</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/sosa/resultTime -->

    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/sosa/resultTime">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label>result time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/hpcc#CoolerSensor -->

    <owl:Class rdf:about="http://example.org/hpcc#CoolerSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment>Represents sensors monitoring Cooler units.</rdfs:comment>
        <rdfs:label>Cooler Sensor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/hpcc#FreeCoolerSensor -->

    <owl:Class rdf:about="http://example.org/hpcc#FreeCoolerSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment>Represents sensors monitoring Free Cooler units.</rdfs:comment>
        <rdfs:label>Free Cooler Sensor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/hpcc#GeneralSensor -->

    <owl:Class rdf:about="http://example.org/hpcc#GeneralSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment>Represents general sensors capturing system states, statuses, or unit-free measurements.</rdfs:comment>
        <rdfs:label>General Sensor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/hpcc#HeatExchangerSensor -->

    <owl:Class rdf:about="http://example.org/hpcc#HeatExchangerSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment>Represents sensors monitoring Heat Exchanger units.</rdfs:comment>
        <rdfs:label>Heat Exchanger Sensor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/hpcc#HeatPumpSensor -->

    <owl:Class rdf:about="http://example.org/hpcc#HeatPumpSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment>Represents sensors monitoring Heat Pump units.</rdfs:comment>
        <rdfs:label>Heat Pump Sensor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/hpcc#MeanObservation -->

    <owl:Class rdf:about="http://example.org/hpcc#MeanObservation">
        <rdfs:subClassOf rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:comment>Represents the calculated mean values of a particular sensors.</rdfs:comment>
        <rdfs:label>Mean Observation</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/hpcc#PumpSensor -->

    <owl:Class rdf:about="http://example.org/hpcc#PumpSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment>Represents sensors monitoring standalone pump units.</rdfs:comment>
        <rdfs:label>Pump Sensor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/hpcc#RecoolerSensor -->

    <owl:Class rdf:about="http://example.org/hpcc#RecoolerSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment>Represents sensors monitoring Recooler units.</rdfs:comment>
        <rdfs:label>Recooler Sensor</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/hpcc#TargetValue -->

    <owl:Class rdf:about="http://example.org/hpcc#TargetValue">
        <rdfs:subClassOf rdf:resource="http://qudt.org/schema/qudt/QuantityValue"/>
        <rdfs:comment>Represents target values or target tolerances of particular sensors.</rdfs:comment>
        <rdfs:label>Target Value</rdfs:label>
    </owl:Class>
    


    <!-- http://qudt.org/schema/qudt/QuantityValue -->

    <owl:Class rdf:about="http://qudt.org/schema/qudt/QuantityValue">
        <rdfs:label>Quantity value</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/FeatureOfInterest -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/FeatureOfInterest">
        <rdfs:label>FeatureOfInterest</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/ObservableProperty -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/ObservableProperty">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/ssn/Property"/>
        <rdfs:label>ObservableProperty</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Observation -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Observation">
        <rdfs:label>Observation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Platform -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Platform">
        <rdfs:label>Platform</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Sensor -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Sensor">
        <rdfs:label>Sensor</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Stimulus -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Stimulus">
        <rdfs:label>Stimulus</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/ssn/System -->

    <owl:Class rdf:about="http://www.w3.org/ns/ssn/System">
        <rdfs:label>System</rdfs:label>
    </owl:Class>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->

    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
