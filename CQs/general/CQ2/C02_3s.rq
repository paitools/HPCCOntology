# 3. What is the target value of the cooler flow-in temperature sensor?

PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX hpcc: <http://example.org/hpcc#>
PREFIX ex: <http://example.org/individuals#>
PREFIX qudt: <http://qudt.org/schema/qudt/>

SELECT ?targetValue
WHERE {
     ex:CoolerFlowInTemperatureSensor hpcc:hasTargetValue ?targetValue .
	  
}