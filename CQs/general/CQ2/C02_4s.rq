# 4. How many heat pumps are installed in the HPC cooling system?

PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX hpcc: <http://example.org/hpcc#>
PREFIX ex: <http://example.org/individuals#>
PREFIX qudt: <http://qudt.org/schema/qudt/>

SELECT (COUNT(DISTINCT ?platform) AS ?heatPumpCount)
WHERE {
  ?sensor a hpcc:HeatPumpSensor ;
          sosa:isHostedBy ?platform .
}