# 2. What was the latest recorded temperature of the HeatPump06?

PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX hpcc: <http://example.org/hpcc#>
PREFIX ex: <http://example.org/individuals#>
PREFIX qudt: <http://qudt.org/schema/qudt/>

SELECT ?observation ?value ?timestamp
WHERE {
  # Step 1: find the latest timestamp
  {
    SELECT (MAX(?t) AS ?latestTime)
    WHERE {
      ?obs a sosa:Observation ;
           sosa:madeBySensor ex:HeatPump06HotWaterFlowInTemperatureSensor ;
           sosa:resultTime ?t .
    }
  }

  # Step 2: return the observation with that timestamp
  ?observation a sosa:Observation ;
               sosa:madeBySensor ex:HeatPump06HotWaterFlowInTemperatureSensor ;
               sosa:resultTime ?timestamp ;
               sosa:hasSimpleResult ?value .

  FILTER(?timestamp = ?latestTime)
}
