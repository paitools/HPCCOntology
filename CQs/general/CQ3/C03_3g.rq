# 3. What are the mean observations of sensors measuring temperature? 

PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX hpcc: <http://example.org/hpcc#>
PREFIX ex: <http://example.org/individuals#>
PREFIX qudt: <http://qudt.org/schema/qudt/>

SELECT DISTINCT ?meanObservation
WHERE {
  ?meanObservation a hpcc:MeanObservation ;
                   sosa:observedProperty ex:Temperature .

}