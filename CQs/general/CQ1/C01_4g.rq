# 4. Which sensors are monitoring the HPC cooling system? 

PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX hpcc: <http://example.org/hpcc#>
PREFIX ex: <http://example.org/individuals#>

SELECT ?sensor 
WHERE {
  ?sensor sosa:observes ?observation . 
  
}