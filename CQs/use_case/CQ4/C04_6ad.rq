# 6. When did the HPC cooling system move to emergency heating state? 

PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX hpcc: <http://example.org/hpcc#>
PREFIX ex: <http://example.org/individuals#>
PREFIX qudt: <http://qudt.org/schema/qudt/>

SELECT ?observation ?sysState
WHERE {  
  ?observation a sosa:Observation ;
               sosa:madeBySensor ex:GeneralOperatingModeSensor ;
               sosa:hasSimpleResult ?sysState .

  FILTER(?sysState = 2.0)
}
